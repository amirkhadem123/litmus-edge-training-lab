# .env.example — Template for the environment variables Litmus Lab needs.
#
# HOW TO USE THIS FILE:
#   1. Copy this file to a new file called '.env' in the same directory:
#        cp .env.example .env        (Linux/Mac)
#        copy .env.example .env      (Windows)
#   2. Fill in the values below with your Litmus Edge credentials.
#   3. The .env file is read at startup by python-dotenv (in main.py).
#
# SECURITY NOTE:
#   The .env file contains secrets (API credentials). It is listed in .gitignore
#   and must NEVER be committed to version control. Only .env.example (with
#   placeholder values) is committed to git.
#
# WHEN RUNNING IN DOCKER:
#   Pass these as -e flags or --env-file instead of relying on the .env file:
#       docker run -p 8000:8000 \
#         -e EDGE_URL=https://192.168.1.50 \
#         -e EDGE_API_CLIENT_ID=your-client-id \
#         -e EDGE_API_CLIENT_SECRET=your-secret \
#         -e VALIDATE_CERTIFICATE=false \
#         litmus-lab
#
# ─────────────────────────────────────────────────────────────────────────────

# EDGE_URL
#   The base URL of the Litmus Edge instance this app will connect to.
#   Must be reachable from wherever this app is running:
#     - Running locally on your laptop: the device's IP on your network
#     - Running inside Litmus Edge's Docker engine: the device's own LAN IP
#       (NOT 'localhost' — that would refer to the container itself)
#   Examples:
#     EDGE_URL=https://192.168.1.50
#     EDGE_URL=https://litmus-edge.local
EDGE_URL=https://YOUR_LITMUS_EDGE_IP_HERE

# EDGE_API_CLIENT_ID and EDGE_API_CLIENT_SECRET
#   OAuth2 credentials for authenticating against the Litmus Edge API.
#   To create these in Litmus Edge:
#     1. Log into the Litmus Edge UI as an administrator.
#     2. Go to System > Access Control > Tokens.
#     3. Click "Add Token" and choose OAuth2 Client type.
#     4. Copy the Client ID and Client Secret into the fields below.
#   The OAuth2 client must have sufficient permissions to:
#     - Create/delete DeviceHub devices and tags
#     - Start/stop devices and services
#     - Create/delete users, groups, and roles
EDGE_API_CLIENT_ID=your-oauth2-client-id-here
EDGE_API_CLIENT_SECRET=your-oauth2-client-secret-here

# VALIDATE_CERTIFICATE
#   Set to 'false' if your Litmus Edge instance uses a self-signed TLS
#   certificate (which is the default for most installations).
#   Set to 'true' only if you have a certificate signed by a trusted CA.
#   WARNING: setting this to 'false' disables TLS verification for the
#   connection to Litmus Edge. Only do this on a trusted internal network.
VALIDATE_CERTIFICATE=false

# SCENARIO_TIMEOUT_MINUTES
#   How long a scenario stays active before auto-teardown fires.
#   This is a safety net to prevent the platform from being left in a
#   broken state if the learner walks away.
#   Default: 30 minutes. Minimum recommended: 10 minutes.
SCENARIO_TIMEOUT_MINUTES=30
