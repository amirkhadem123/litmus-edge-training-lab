# .env.example — Environment variables for Litmus Lab Zendesk training system.
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in the values below, then run scripts normally.
#
# SECURITY: Never commit .env to version control. Only .env.example is committed.
# ─────────────────────────────────────────────────────────────────────────────

# ZENDESK_SUBDOMAIN
#   Your Zendesk instance subdomain. If your Zendesk URL is
#   acme.zendesk.com, set this to: acme
ZENDESK_SUBDOMAIN=your-subdomain

# ZENDESK_EMAIL
#   Email address of the Zendesk service account used by Litmus Lab.
#   This account creates tickets and posts internal notes.
#   Should NOT be a real support agent account — create a dedicated one.
ZENDESK_EMAIL=litmus-lab@yourcompany.com

# ZENDESK_API_TOKEN
#   API token for the service account above.
#   To generate: Zendesk Admin Center → Apps & Integrations → APIs → Zendesk API
#   → Settings → Token access (enable) → Add API token
ZENDESK_API_TOKEN=your-api-token-here

# ANTHROPIC_API_KEY
#   Claude API key used to grade trainee responses.
#   Obtain from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
