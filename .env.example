# .env.example — Environment variables for Litmus Lab.
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in your Anthropic API key, then start the server:
#     uvicorn app.main:app --reload
#
# SECURITY: Never commit .env to version control. Only .env.example is committed.
# ─────────────────────────────────────────────────────────────────────────────

# LITMUS_MODEL
#   The LLM model used for grading. Defaults to Claude Haiku if not set.
#   Any LiteLLM-supported model string works — set the matching API key below.
#
#   Examples:
#     claude-haiku-4-5-20251001   (Anthropic — default)
#     gpt-4o-mini                 (OpenAI)
#     gemini/gemini-1.5-flash     (Google)
#     azure/gpt-4o-mini           (Azure OpenAI — also set AZURE_API_BASE, AZURE_API_VERSION)
#
# LITMUS_MODEL=claude-haiku-4-5-20251001

# API key for your chosen provider (set only the one you need):
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-openai-key
# GEMINI_API_KEY=your-gemini-key
